---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getConfig } from '../lib/data';
import { tinaFormPayload } from '../lib/tina-forms';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const configResult = await getConfig();
const config = configResult.data?.config ?? null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<Fragment set:html={tinaFormPayload(configResult)} />
		<script is:inline type="module">
			if (window.self !== window.top && !window.__tinaBootstrap) {
				window.__tinaBootstrap = 1;
				const { init, refreshForms } = await import('/admin/bridge.js');
				init();
				document.addEventListener('astro:page-load', refreshForms);
			}
		</script>
		<Header config={config} />
		<slot />
		<Footer config={config} />
	</body>
</html>
