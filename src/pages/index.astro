---
import Base from '../layouts/Base.astro';
import PageBody from '../components/islands/PageBody.astro';
import { getConfig, getPage } from '../lib/data';
import { tinaFormPayload } from '../lib/tina-forms';

const slug = 'home';
const page = await getPage(slug);
const data = page.data?.page;
if (!data) return new Response('Not Found', { status: 404 });
const config = (await getConfig()).data?.config ?? null;
---

<Base
	title={data.seoTitle || config?.seo?.title || 'TinaCMS + Astro'}
	description={config?.seo?.description ?? 'Welcome to my website!'}
>
	<Fragment set:html={tinaFormPayload(page, true)} />
	<main>
		<PageBody data={data} />
	</main>
</Base>
